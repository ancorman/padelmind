# PadelMind Pi Recorder — config
# Copy this to config.env and fill in real values before running install.sh

# Supabase (padelmind project — ddvntjalhtdutmcknshr)
PADEL_SUPABASE_URL=https://ddvntjalhtdutmcknshr.supabase.co
PADEL_SUPABASE_KEY=<service_role_key_here>

# Comma-separated UUIDs of the courts this Pi manages
# Find these with: SELECT id, name FROM padel_courts;
PADEL_COURT_IDS=<court1_uuid>,<court2_uuid>

# Cloudflare R2
PADEL_R2_ACCOUNT_ID=<cloudflare_account_id>
PADEL_R2_ACCESS_KEY=<r2_access_key_id>
PADEL_R2_SECRET_KEY=<r2_secret_access_key>
PADEL_R2_BUCKET=padelmind-videos

# Cloudflare Worker — base URL, no path (recorder posts to /api/matches/:id/uploaded)
PADEL_WORKER_URL=https://padelmind-api.<your-subdomain>.workers.dev
PADEL_PI_SECRET=<same value as the Worker's PI_SHARED_SECRET>

# Camera devices
# Run: v4l2-ctl --list-devices  to find the right paths
CAMERA_DEVICE_0=/dev/video0
CAMERA_DEVICE_1=/dev/video2

# Optional
SEGMENTS_DIR=/tmp/padelmind
POLL_INTERVAL=5
